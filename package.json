{
  "name": "cli-agent-core",
  "version": "0.0.1",
  "private": true,
  "description": "CLI Agent Core - Interactive CLI agent with multi-LLM support",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "test:e2e": "pnpx vitest run --config tests/e2e/vitest.config.ts",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "vitest": "^1.6.1"
  }
}
