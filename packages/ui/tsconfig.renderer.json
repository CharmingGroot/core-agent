{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/renderer",
    "rootDir": "./src/renderer",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noUnusedLocals": false
