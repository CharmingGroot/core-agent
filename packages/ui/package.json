{
  "name": "@cli-agent/ui",
  "version": "0.0.1",
  "private": true,
  "description": "CLI Agent Desktop - Electron UI for interactive agent sessions",
  "author": "CLI Agent Team",
  "type": "module",
  "main": "./dist/main/main.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "node scripts/build-renderer.mjs",
    "build:electron": "node scripts/build.mjs",
    "dist": "node scripts/build.mjs && electron-builder --config electron-builder.config.cjs",
    "test": "vitest run",
    "dev": "electron ./dist/main/main.cjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cli-agent/core": "workspace:*",
    "@cli-agent/providers": "workspace:*",
    "@cli-agent/tools": "workspace:*",
    "@cli-agent/agent": "workspace:*",
    "@core/types": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "esbuild": "^0.21.0",
    "jsdom": "^24.0.0"
  }
}
